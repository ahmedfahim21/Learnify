# --- AWS Bedrock (Claude tutor) ---
# Credentials for invoking Claude models via the Bedrock Runtime.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1

# Bedrock model IDs (carry the `anthropic.` provider prefix).
# TUTOR_MODEL drives the live teaching loop (A2UI emission via strict tools).
# UTILITY_MODEL handles cheaper background work (summaries, grading, graphs).
TUTOR_MODEL=anthropic.claude-fable-5
UTILITY_MODEL=anthropic.claude-haiku-4-5

# --- Database (Neon Postgres) ---
# Pooled connection string from your Neon project. Builds and lint pass
# without this set; it is only required at runtime for DB access.
DATABASE_URL=

# --- Source ingestion (PDF uploads) ---
# Read/write token for Vercel Blob. Required only to attach PDF sources to a
# topic (the bytes are stored here and base64'd into requests at session time —
# Bedrock has no Files API). URL and YouTube sources work without it. Get one
# from your Vercel project → Storage → Blob.
BLOB_READ_WRITE_TOKEN=

# --- Tutor memory (Supermemory) ---
# Optional. When set, the tutor's qualitative memory of *how* each learner
# learns is backed by Supermemory (semantic recall, user-scoped containers).
# Leave it unset to use the plain-Postgres `learner_notes` fallback instead —
# the app runs fully either way.
SUPERMEMORY_API_KEY=
