# --- AWS Bedrock (Claude tutor) ---
# Credentials for invoking Claude models via the Bedrock Runtime.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1

# Bedrock model IDs (carry the `anthropic.` provider prefix).
# TUTOR_MODEL drives the live teaching loop (A2UI emission via strict tools).
# UTILITY_MODEL handles cheaper background work (summaries, grading, graphs).
TUTOR_MODEL=anthropic.claude-fable-5
UTILITY_MODEL=anthropic.claude-haiku-4-5

# --- Database (Neon Postgres) ---
# Pooled connection string from your Neon project. Builds and lint pass
# without this set; it is only required at runtime for DB access.
DATABASE_URL=
